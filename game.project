[bootstrap]
main_collection = /main/main.collectionc
render = /builtins/render/default.renderc

[script]
shared_state = 1

[display]
width = 800
height = 600
high_dpi = 1

[android]
input_method = HiddenInputField

[project]
title = extension-db
write_log_file = 1
custom_resources = /custom_res
minimum_log_level = 1

[physics]
debug = 1

[render]
clear_color_green = 0.2
clear_color_blue = 0.2
clear_color_red = 0.2

[library]
include_dirs = dragonbones

