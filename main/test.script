local function spawn_mesh(no)
	local z = -1 + 0.01 * no
	local id = factory.create("#factory", vmath.vector3(0, 0, z), nil, nil, vmath.vector3(1, 1, 1))
	return msg.url(nil, id, "mesh" )
end

local function set_mesh_data(self, mesh_no, buffer_data)
	--pprint(buffer_data.mtx_model)
	local mesh_id = self.meshes[mesh_no]
	--print(mesh_id)
	
	go.set(mesh_id, hash("u_mtx_mvp"),     buffer_data.mtx_mvp)
	--go.set(mesh_id, hash("u_mtx_model"),   buffer_data.mtx_model)
	--go.set(mesh_id, hash("u_mtx_view"),    buffer_data.mtx_view)
	local buffer_name = self.buffer_prefix_name .. tostring(mesh_no) .. ".bufferc"
	
	--local my_buffer = resource.create_buffer(buffer_name, 
	--{ buffer = buffer_data.buffer }) --triangles_list

	local my_buffer = resource.create_buffer(buffer_name, 
	{ buffer = buffer_data.buffer_trilist }) --triangles

	go.set(mesh_id, hash("vertices"), my_buffer )
	table.insert(self.current_buffers, my_buffer)
end

local function update_db_world(self)
	--release previous buffers
	
	
	--update animation and get buffers
	dragonbones.update(self.instance)
	local buffer_table = dragonbones.get_buffers(self.instance)
	--test(buffer_table)
	
	for k,v in ipairs(buffer_table) do
		set_mesh_data(self, k, v)
		--test(v)
		--if k == 3 then break end
	end

	for i = 1, #self.previous_buffers do
		resource.release(self.previous_buffers[i])
		--resource.release(path)
	end
	collectgarbage("collect")
end

function init(self)
	msg.post(".", "acquire_input_focus")

	profiler.enable_ui(true)

	--initiate dragon bones and upload json data
	self.instance = dragonbones.create(1600, 1200)
	dragonbones.load_data(self.instance, skeleton_json, tex_json)
	

	self.buffer_prefix_name = "/" .. create_buffer_prefix_name()
	self.current_buffers = {}
	self.previous_buffers = {}
	
	self.meshes  = {}
	local no_slots = dragonbones.get_no_slots(self.instance)
	for i = 1, no_slots do
		local mesh_id = spawn_mesh(i)
		table.insert(self.meshes, mesh_id)
	end

	local tbl_animations = dragonbones.get_anination_names(self.instance)
	--pprint(tbl_animations)
	dragonbones.fade_in_animation(self.instance, tbl_animations[1], 0, 0, 0)
	dragonbones.set_world_translation(self.instance, 0, 200)

	self.buffer_prefix_name = "/" .. create_buffer_prefix_name()
	update_db_world(self)
	--[
	timer.delay(1/60, true, function()
		--print("Updating  .........................................")
		self.previous_buffers = self.current_buffers
		self.current_buffers  = {}
		self.buffer_prefix_name = "/" .. create_buffer_prefix_name()
		update_db_world(self)
	end)
	--]]
	
	
end
