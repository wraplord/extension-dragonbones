local skeleton_json = "/custom_res/character4/Bicycle_ske.json"
local tex_json = "/custom_res/character4/Bicycle_tex.json"
local tex_png = "/custom_res/character4/Bicycle_tex.png"

function init(self)
	msg.post(".", "acquire_input_focus")
	local tbl = {
		skeleton_json = skeleton_json, 
		tex_json = tex_json,
		tex_png = tex_png
	}
	
	msg.post("/DragonModel", hash("load"), tbl)
	msg.post("/DragonModel", hash("instance"), tbl)

	timer.delay(1/30.0, true, function()
		if self.instance then --loaded
			msg.post("/DragonModel", hash("update"), { dt = 1/30.0 })
		end
	end)
end

function on_message(self, message_id, message, sender)
	if message_id == hash("instance") then   
		self.instance = message.instance
		dragonbones.set_world_translation(self.instance, 0, 100)
	end
end