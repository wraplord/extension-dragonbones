go.property("my_texture", resource.texture()) --custom texture for swapping
local module_instance = require("dragonbones.shared.instance")


local function getInitData(folder_prefix, buffer_prefix)
	local skeleton_json = "/custom_res/" .. folder_prefix .. "_ske.json"
	local tex_json      = "/custom_res/" .. folder_prefix .. "_tex.json"
	return {
		skeleton_json = skeleton_json, 
		tex_json = tex_json,
		buffer_prefix = buffer_prefix
	}
end

function init(self)
	if profiler then
		profiler.enable_ui(true)
		profiler.set_ui_view_mode(profiler.VIEW_MODE_MINIMIZED)
	end
	
	msg.post(".", "acquire_input_focus")
	math.randomseed(socket.gettime())
	for i = 1, 4 do math.random(1, 10) end
	

	self.instance = nil
	self.bicycle1_name = module_instance.create_buffer_prefix_name()
	self.bicycle2_name = module_instance.create_buffer_prefix_name()
	self.bicycle3_name = module_instance.create_buffer_prefix_name()
	self.bicycle4_name = module_instance.create_buffer_prefix_name()

	local tbl11 = getInitData("character4/Bicycle", self.bicycle1_name)
	local tbl12 = getInitData("character4/Bicycle", self.bicycle2_name)
	local tbl13 = getInitData("character4/Bicycle", self.bicycle3_name)
	local tbl14 = getInitData("character4/Bicycle", self.bicycle4_name)
	
	self.rooster_name = module_instance.create_buffer_prefix_name()
	local tbl2 = getInitData("character2/Rooster_Ani", self.rooster_name)

	msg.post("/Bicycle1",  hash("load"), tbl11)
	msg.post("/Bicycle2",  hash("load"), tbl12)
	msg.post("/Bicycle3",  hash("load"), tbl13)
	msg.post("/Bicycle4",  hash("load"), tbl14)
	
	msg.post("/Rooster", hash("load"), tbl2)
	
	go.animate("/Bicycle1", "position.x", go.PLAYBACK_LOOP_PINGPONG, -400, 
	go.EASING_LINEAR, 5)
	go.animate("/Bicycle2", "position.x", go.PLAYBACK_LOOP_FORWARD, -400, 
	go.EASING_LINEAR, 4)
	go.animate("/Bicycle3", "position.x", go.PLAYBACK_LOOP_FORWARD, -300, 
	go.EASING_LINEAR, 8)
	--go.animate("/Bicycle4", "position.x", go.PLAYBACK_LOOP_FORWARD, -359, 
	--go.EASING_LINEAR, 5)

end

local function walk(self, instance, flip)
	local p = go.get_position("/Rooster")
	dragonbones.set_flip_x(instance, not flip)

	--override flipping of some slots	
	local scale_x = flip and 1.0 or -1.0
	dragonbones.set_slot_scale(instance, "copyrights", scale_x, 1.0)

	local d = flip and -400 or 400
	go.animate("/Rooster", "position.x", go.PLAYBACK_ONCE_FORWARD, p.x + d, go.EASING_LINEAR, 5, 0, function()
		walk(self, instance, not flip)
	end)
	
end

function on_message(self, message_id, message)
	if message_id == hash("loaded") then
		local instance = module_instance.instances[message.instance_name]
		print("Instance FPS", dragonbones.get_frame_rate(instance))
		--use game object for instance transform
		
		if message.instance_name == self.rooster_name then
			walk(self, instance, true)
			pprint(dragonbones.get_anination_names(instance))
			dragonbones.fade_in_animation(instance, "rooster_walk_anim", 0, 0, 0.2)
			timer.delay(1/24.0, true, function()
				msg.post("/Rooster", hash("update"), { dt = 1/24.0 })
			end)
		elseif message.instance_name ==  self.bicycle1_name then
			timer.delay(1/30.0, true, function()
				msg.post("/Bicycle1", hash("update"), { dt = 1/30.0 })
			end)
			--SIMPLE TEXTURE SWAPPING
			timer.delay(10, false, function()
				local tex_name = "my_unique_texture_id"
				module_instance.textures[tex_name] = hash(self.my_texture) -- from go.property
				msg.post("/Bicycle1", hash("swap_texture"), {texture_name = tex_name})
			end)
		elseif message.instance_name ==  self.bicycle2_name then
			timer.delay(1/30.0, true, function()
				msg.post("/Bicycle2", hash("update"), { dt = 1/30.0 })
			end)
			msg.post("/Bicycle2", hash("tint"), {tint = vmath.vector4(1.0, 0.0, 0.0, 1.0)})
		elseif message.instance_name == self.bicycle3_name then
			timer.delay(1/30.0, true, function()
				msg.post("/Bicycle3", hash("update"), { dt = 1/30.0 })
			end)
		elseif message.instance_name == self.bicycle4_name then
			--static
			--timer.delay(1/30.0, true, function()
			--	msg.post("/Bicycle3", hash("update"), { dt = 1/30.0 })
			--end)
		end
		
		--dragonbones.add_event_callback(instance, function(me, tbl)
		--	pprint(tbl)
		--end)
		
		--dragonbones.set_slot_visibility(instance, "head", false)
		--dragonbones.set_flip_x(instance, true)
		--dragonbones.set_bone_rotation(instance, "root", math.rad(-60))
		--dragonbones.set_bone_position(instance, "root", 10, 30)
	end
end

