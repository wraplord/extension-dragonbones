local module_instance = require("dragonbones.shared.instance")

local folder = "character4/Bicycle"
local skeleton_json = "/custom_res/" .. folder .. "_ske.json"
local tex_json      = "/custom_res/" .. folder .. "_tex.json"

function init(self)
	if profiler then
		profiler.enable_ui(true)
		profiler.set_ui_view_mode(profiler.VIEW_MODE_MINIMIZED)
	end
	
	msg.post(".", "acquire_input_focus")

	self.instance = nil
	local tbl = {
		skeleton_json = skeleton_json, 
		tex_json = tex_json,
	}
	
	msg.post("/BatchDragonModel", hash("load"), tbl)
	--[[go.animate("/BatchDragonModel", "position.x", go.PLAYBACK_LOOP_PINGPONG, 100, 
	   go.EASING_LINEAR, 5)
	go.animate("/BatchDragonModel", "position.y", go.PLAYBACK_LOOP_PINGPONG, -100, 
	go.EASING_LINEAR, 10)
	--]]

	go.animate("/BatchDragonModel", "euler.z", go.PLAYBACK_LOOP_FORWARD, 359, 
	go.EASING_LINEAR, 10)
	
end

local function update_world(self)
	timer.delay(1/30.0, true, function()
		msg.post("/BatchDragonModel", hash("update"), { dt = 1/30.0 })
	end)
end

function on_message(self, message_id, message)
	if message_id == hash("loaded") then
		update_world(self)
		self.instance = module_instance.instances[message.instance_no]
		if self.instance then
			dragonbones.move(self.instance, 0, 200)
			
			--local x = 100
			--timer.delay(1/30, true, function()
			--	x = x - 5
			--	dragonbones.move(self.instance, x, 100)
			--end) --test culling

			
			--dragonbones.add_event_callback(self.instance, function(me, tbl)
			--	pprint(tbl)
			--end)

			
			--dragonbones.set_slot_visibility(self.instance, "head", false)
			--dragonbones.set_flip_x(self.instance, true)
			--dragonbones.set_bone_rotation(self.instance, "head", math.rad(-60))
			--dragonbones.set_bone_position(self.instance, "head", 100, 1)
			print(dragonbones.get_frame_rate(self.instance))
		end
	end
end

